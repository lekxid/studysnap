@import "tailwindcss";

:root {
  --background: #071018;
  --background-soft: #0b1623;
  --foreground: #f5f7fa;
  --muted: #8fa3b8;
  --card: rgba(12, 23, 34, 0.72);
  --card-strong: rgba(9, 18, 29, 0.9);
  --border: rgba(255, 255, 255, 0.1);
  --cyan: #22d3ee;
  --cyan-strong: #06b6d4;
  --gold: #fbbf24;
  --gold-soft: #fde68a;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: Arial, Helvetica, sans-serif;
  --font-mono: monospace;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

html,
body {
  max-width: 100vw;
  overflow-x: hidden;
}

body {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(34, 211, 238, 0.12), transparent 30%),
    radial-gradient(circle at 85% 12%, rgba(251, 191, 36, 0.1), transparent 18%),
    linear-gradient(180deg, #071018 0%, #09131d 38%, #0a1118 100%);
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
textarea,
select {
  font: inherit;
}

::selection {
  background: rgba(34, 211, 238, 0.25);
  color: #ffffff;
}

input,
textarea,
select {
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.1);
  outline: none;
  transition:
    border-color 0.2s ease,
    box-shadow 0.2s ease,
    background 0.2s ease;
}

input::placeholder,
textarea::placeholder {
  color: rgba(143, 163, 184, 0.85);
}

input:focus,
textarea:focus,
select:focus {
  border-color: rgba(34, 211, 238, 0.6);
  box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.12);
  background: rgba(255, 255, 255, 0.07);
}

button {
  transition:
    transform 0.18s ease,
    opacity 0.18s ease,
    box-shadow 0.18s ease,
    background 0.18s ease,
    border-color 0.18s ease;
}

button:hover {
  transform: translateY(-1px);
}

.premium-bg {
  background:
    radial-gradient(circle at top, rgba(34, 211, 238, 0.12), transparent 30%),
    radial-gradient(circle at 85% 12%, rgba(251, 191, 36, 0.08), transparent 18%),
    linear-gradient(180deg, #071018 0%, #09131d 38%, #0a1118 100%);
}

.premium-card {
  background: rgba(12, 23, 34, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.35);
}

.premium-card-strong {
  background: rgba(9, 18, 29, 0.9);
  border: 1px solid rgba(34, 211, 238, 0.18);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow:
    0 0 0 1px rgba(34, 211, 238, 0.08),
    0 18px 60px rgba(0, 0, 0, 0.4);
}

.premium-button {
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.98), rgba(8, 145, 178, 0.95));
  color: #041018;
  box-shadow: 0 12px 30px rgba(34, 211, 238, 0.22);
}

.premium-button:hover {
  box-shadow: 0 16px 36px rgba(34, 211, 238, 0.28);
}

.premium-button-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.premium-button-secondary:hover {
  background: rgba(34, 211, 238, 0.08);
  border-color: rgba(34, 211, 238, 0.25);
}

.gold-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  border-radius: 9999px;
  padding: 0.45rem 0.8rem;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  color: #fde68a;
  background: rgba(251, 191, 36, 0.08);
  border: 1px solid rgba(251, 191, 36, 0.22);
}

.page-wrap {
  width: 100%;
  max-width: 88rem;
  margin: 0 auto;
  padding-left: 1rem;
  padding-right: 1rem;
}

@media (min-width: 640px) {
  .page-wrap {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
}

@media (min-width: 1024px) {
  .page-wrap {
    padding-left: 2rem;
    padding-right: 2rem;
  }
}
