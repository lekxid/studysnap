"use client";

import Link from "next/link";
import { usePathname, useRouter } from "next/navigation";
import { ReactNode, useState } from "react";
import { removeToken } from "@/lib/api";
import NotificationBell from "@/components/NotificationBell";

const navItems = [
  { href: "/dashboard", label: "Dashboard", icon: "◈" },
  { href: "/onboarding", label: "Onboarding", icon: "◎" },
  { href: "/ai-tutor", label: "AI Tutor", icon: "✦" },
  { href: "/notes", label: "Notes", icon: "▣" },
  { href: "/study-rooms", label: "Study Rooms", icon: "⬢" },
  { href: "/planner", label: "Planner", icon: "◷" },
  { href: "/flashcards", label: "Flashcards", icon: "◫" },
  { href: "/quizzes", label: "Quizzes", icon: "✎" },
  { href: "/groups", label: "Groups", icon: "◌" },
  { href: "/progress", label: "Progress", icon: "▲" },
  { href: "/settings", label: "Settings", icon: "⚙" },
];

export default function AppShell({
  title,
  subtitle,
  children,
}: {
  title: string;
  subtitle?: string;
  children: ReactNode;
}) {
  const pathname = usePathname();
  const router = useRouter();
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

  function handleLogout() {
    removeToken();
    router.push("/login");
  }

  return (
    <div className="premium-bg min-h-screen text-white">
      <div className="flex min-h-screen">
        <aside className="premium-card-strong soft-scroll sticky top-0 hidden h-screen w-80 flex-col overflow-y-auto rounded-none border-r border-white/8 md:flex">
          <div className="border-b border-white/8 px-7 py-7">
            <Link href="/dashboard" className="block">
              <div className="gold-chip mb-5">Premium Study Flow</div>
              <h1 className="text-[2.6rem] font-black tracking-[-0.04em] text-transparent bg-gradient-to-r from-cyan-300 via-sky-300 to-violet-300 bg-clip-text">
                StudySnap AI
              </h1>
              <p className="mt-3 max-w-xs text-[1rem] leading-8 text-slate-300">
                Learn faster. Study smarter. Stay consistent.
              </p>
            </Link>
          </div>

          <nav className="flex-1 space-y-3 px-5 py-6">
            {navItems.map((item) => {
              const active =
                pathname === item.href || pathname.startsWith(`${item.href}/`);

              return (
                <Link
                  key={item.href}
                  href={item.href}
                  className={`group flex items-center gap-4 rounded-[1.4rem] px-5 py-4 text-[0.98rem] font-semibold transition ${
                    active
                      ? "bg-gradient-to-r from-violet-500/92 via-indigo-500/90 to-sky-500/85 text-white shadow-[0_16px_34px_rgba(109,94,252,0.28)]"
                      : "text-slate-300 hover:bg-white/[0.06] hover:text-white"
                  }`}
                >
                  <span
                    className={`inline-flex h-10 w-10 items-center justify-center rounded-2xl text-sm ${
                      active
                        ? "bg-white/18 text-white"
                        : "bg-white/5 text-sky-300 group-hover:bg-violet-500/12"
                    }`}
                  >
                    {item.icon}
                  </span>
                  <span>{item.label}</span>
                </Link>
              );
            })}
          </nav>

          <div className="border-t border-white/8 p-5">
            <div className="premium-card rounded-[1.6rem] p-5">
              <p className="text-sm font-bold text-sky-300">Today’s Mission</p>
              <ul className="mt-4 space-y-3 text-sm leading-7 text-slate-300">
                <li>• Review flashcards</li>
                <li>• Ask AI one hard question</li>
                <li>• Study for 20 minutes</li>
              </ul>
              <div className="mt-5 rounded-2xl border border-amber-300/15 bg-amber-400/10 px-3 py-2.5 text-xs font-medium text-amber-100">
                Small daily wins build real progress.
              </div>
            </div>
          </div>
        </aside>

        <div className="flex min-w-0 flex-1 flex-col">
          <header className="sticky top-0 z-40 border-b border-white/8 bg-slate-950/78 backdrop-blur-xl">
            <div className="page-wrap flex min-h-[92px] items-center justify-between gap-5 py-5">
              <div className="flex min-w-0 items-center gap-4">
                <button
                  type="button"
                  onClick={() => setMobileMenuOpen((prev) => !prev)}
                  className="premium-button-secondary inline-flex h-12 w-12 items-center justify-center rounded-2xl md:hidden"
                  aria-label="Toggle menu"
                >
                  ☰
                </button>

                <div className="min-w-0">
                  <div className="mb-3 hidden md:inline-flex rounded-full border border-amber-300/20 bg-amber-400/10 px-3 py-1 text-xs font-semibold text-amber-100">
                    Focus Mode
                  </div>
                  <h2 className="section-heading truncate text-white">{title}</h2>
                  {subtitle ? (
                    <p className="section-subtitle mt-2 max-w-3xl">{subtitle}</p>
                  ) : null}
                </div>
              </div>

              <div className="flex shrink-0 items-center gap-3 md:gap-4">
                <div className="rounded-[1.35rem] border border-white/10 bg-slate-900/90 px-4 py-3 text-slate-200 shadow-[0_10px_26px_rgba(0,0,0,0.22)]">
                  <NotificationBell />
                </div>

                <button
                  onClick={handleLogout}
                  className="premium-button-secondary rounded-[1.15rem] px-5 py-3 text-sm font-semibold"
                >
                  Logout
                </button>
              </div>
            </div>

            {mobileMenuOpen ? (
              <div className="border-t border-white/8 bg-slate-950/95 px-4 py-4 md:hidden">
                <nav className="space-y-2">
                  {navItems.map((item) => {
                    const active =
                      pathname === item.href ||
                      pathname.startsWith(`${item.href}/`);

                    return (
                      <Link
                        key={item.href}
                        href={item.href}
                        onClick={() => setMobileMenuOpen(false)}
                        className={`flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold ${
                          active
                            ? "bg-gradient-to-r from-violet-500/95 via-indigo-500/92 to-sky-500/85 text-white"
                            : "bg-white/5 text-slate-200"
                        }`}
                      >
                        <span className="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-white/10 text-sky-300">
                          {item.icon}
                        </span>
                        <span>{item.label}</span>
                      </Link>
                    );
                  })}
                </nav>
              </div>
            ) : null}
          </header>

          <main className="page-wrap w-full flex-1 py-8 sm:py-10">
            <div className="app-content">{children}</div>
          </main>
        </div>
      </div>
    </div>
  );
}
