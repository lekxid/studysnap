"use client";

import Link from "next/link";
import { usePathname, useRouter } from "next/navigation";
import { ReactNode, useState } from "react";
import { removeToken } from "@/lib/api";
import NotificationBell from "@/components/NotificationBell";

const navItems = [
  { href: "/dashboard", label: "Dashboard", icon: "◈" },
  { href: "/onboarding", label: "Onboarding", icon: "◎" },
  { href: "/ai-tutor", label: "AI Tutor", icon: "✦" },
  { href: "/notes", label: "Notes", icon: "▣" },
  { href: "/study-rooms", label: "Study Rooms", icon: "⬢" },
  { href: "/planner", label: "Planner", icon: "◷" },
  { href: "/flashcards", label: "Flashcards", icon: "◫" },
  { href: "/quizzes", label: "Quizzes", icon: "✎" },
  { href: "/groups", label: "Groups", icon: "◌" },
  { href: "/progress", label: "Progress", icon: "▲" },
  { href: "/settings", label: "Settings", icon: "⚙" },
];

export default function AppShell({
  title,
  subtitle,
  children,
}: {
  title: string;
  subtitle?: string;
  children: ReactNode;
}) {
  const pathname = usePathname();
  const router = useRouter();
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

  function handleLogout() {
    removeToken();
    router.push("/login");
  }

  return (
    <div className="premium-bg min-h-screen text-white">
      <div className="flex min-h-screen">
        <aside className="premium-card-strong sticky top-0 hidden h-screen w-72 flex-col rounded-none border-r border-white/10 md:flex">
          <div className="border-b border-white/10 px-6 py-6">
            <Link href="/dashboard" className="block">
              <div className="gold-chip mb-4">Premium Study Flow</div>
              <h1 className="text-3xl font-black tracking-tight text-cyan-300">
                StudySnap AI
              </h1>
              <p className="mt-2 text-sm leading-6 text-slate-400">
                Learn faster. Study smarter. Stay consistent.
              </p>
            </Link>
          </div>

          <nav className="flex-1 space-y-2 overflow-y-auto px-4 py-6">
            {navItems.map((item) => {
              const active = pathname === item.href;
              return (
                <Link
                  key={item.href}
                  href={item.href}
                  className={`group flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold transition ${
                    active
                      ? "bg-cyan-400 text-slate-950 shadow-[0_10px_28px_rgba(34,211,238,0.25)]"
                      : "text-slate-300 hover:border-white/10 hover:bg-white/6 hover:text-white"
                  }`}
                >
                  <span
                    className={`inline-flex h-8 w-8 items-center justify-center rounded-xl text-sm ${
                      active
                        ? "bg-white/30 text-slate-950"
                        : "bg-white/5 text-cyan-300 group-hover:bg-cyan-400/10"
                    }`}
                  >
                    {item.icon}
                  </span>
                  <span>{item.label}</span>
                </Link>
              );
            })}
          </nav>

          <div className="border-t border-white/10 p-4">
            <div className="premium-card rounded-3xl p-4">
              <p className="text-sm font-bold text-cyan-300">Today’s Mission</p>
              <ul className="mt-3 space-y-2 text-sm text-slate-300">
                <li>• Review flashcards</li>
                <li>• Ask AI one hard question</li>
                <li>• Study for 20 minutes</li>
              </ul>
              <div className="mt-4 rounded-2xl border border-amber-300/15 bg-amber-400/8 px-3 py-2 text-xs font-medium text-amber-100">
                Small daily wins build real progress.
              </div>
            </div>
          </div>
        </aside>

        <div className="flex min-w-0 flex-1 flex-col">
          <header className="sticky top-0 z-40 border-b border-white/10 bg-slate-950/70 backdrop-blur-xl">
            <div className="page-wrap flex min-h-[76px] items-center justify-between gap-4 py-4">
              <div className="flex min-w-0 items-center gap-3">
                <button
                  type="button"
                  onClick={() => setMobileMenuOpen((prev) => !prev)}
                  className="premium-button-secondary inline-flex h-11 w-11 items-center justify-center rounded-2xl md:hidden"
                  aria-label="Toggle menu"
                >
                  ☰
                </button>

                <div className="min-w-0">
                  <div className="mb-2 hidden md:inline-flex rounded-full border border-amber-300/20 bg-amber-400/8 px-3 py-1 text-xs font-semibold text-amber-100">
                    Focus Mode
                  </div>
                  <h2 className="truncate text-2xl font-black tracking-tight text-white md:text-3xl">
                    {title}
                  </h2>
                  {subtitle ? (
                    <p className="mt-1 max-w-2xl text-sm text-slate-400">
                      {subtitle}
                    </p>
                  ) : null}
                </div>
              </div>

              <div className="flex shrink-0 items-center gap-2 sm:gap-3">
                <div className="rounded-2xl border border-white/10 bg-white/5 p-1.5 sm:p-2">
                  <NotificationBell />
                </div>

                <button
                  onClick={handleLogout}
                  className="premium-button-secondary rounded-2xl px-4 py-2.5 text-sm font-semibold"
                >
                  Logout
                </button>
              </div>
            </div>

            {mobileMenuOpen ? (
              <div className="border-t border-white/10 bg-slate-950/95 px-4 py-4 md:hidden">
                <nav className="space-y-2">
                  {navItems.map((item) => {
                    const active = pathname === item.href;
                    return (
                      <Link
                        key={item.href}
                        href={item.href}
                        onClick={() => setMobileMenuOpen(false)}
                        className={`flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold ${
                          active
                            ? "bg-cyan-400 text-slate-950"
                            : "bg-white/5 text-slate-200"
                        }`}
                      >
                        <span className="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-white/10 text-cyan-300">
                          {item.icon}
                        </span>
                        <span>{item.label}</span>
                      </Link>
                    );
                  })}
                </nav>
              </div>
            ) : null}
          </header>

          <main className="page-wrap w-full flex-1 py-6 sm:py-8">
            {children}
          </main>
        </div>
      </div>
    </div>
  );
}
