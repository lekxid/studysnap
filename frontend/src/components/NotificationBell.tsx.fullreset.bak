"use client";

import { useEffect, useState } from "react";
import { loadJSON, saveJSON } from "@/lib/storage";

type Notice = {
  id: number;
  text: string;
  createdAt: string;
};

const STORAGE_KEY = "studysnap_notifications";

export default function NotificationBell() {
  const [open, setOpen] = useState(false);
  const [items, setItems] = useState<Notice[]>([]);

  useEffect(() => {
    setItems(loadJSON<Notice[]>(STORAGE_KEY, []));
  }, []);

  function clearAll() {
    setItems([]);
    saveJSON(STORAGE_KEY, []);
  }

  return (
    <div className="relative">
      <button
        onClick={() => setOpen((v) => !v)}
        className="rounded-xl border border-white/20 px-4 py-2 text-sm font-semibold text-black bg-white"
      >
        Notifications ({items.length})
      </button>

      {open ? (
        <div className="absolute right-0 z-50 mt-3 w-96 rounded-2xl border border-white/10 bg-[#0a1022] p-4 text-white shadow-2xl">
          <div className="flex items-center justify-between">
            <h3 className="text-lg font-semibold text-cyan-300">Notifications</h3>
            <button
              onClick={clearAll}
              className="text-sm text-red-300"
            >
              Clear all
            </button>
          </div>

          {items.length === 0 ? (
            <div className="mt-4 rounded-xl bg-white/5 p-4 text-white/70">
              No notifications yet.
            </div>
          ) : (
            <div className="mt-4 space-y-3">
              {items.map((item) => (
                <div key={item.id} className="rounded-xl bg-white/5 p-4">
                  <p className="text-sm text-white">{item.text}</p>
                  <p className="mt-2 text-xs text-white/50">{item.createdAt}</p>
                </div>
              ))}
            </div>
          )}
        </div>
      ) : null}
    </div>
  );
}
